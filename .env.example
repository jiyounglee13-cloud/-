# Anthropic Claude API 키 (필수)
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# 사용할 모델 (선택, 기본값: claude-opus-4-8)
# 비용을 낮추려면 claude-sonnet-4-6 등으로 변경 가능
APPEAL_MODEL=claude-opus-4-8

# ── 외부 임베딩 벡터 검색 (선택) ────────────────────────────────────
# 아래 두 값이 모두 설정되면 RAG 검색이 로컬 해싱 TF-IDF 대신 외부
# OpenAI 호환 임베딩 엔드포인트를 사용합니다. 미설정 시 키 없이 로컬로 동작합니다.
# EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536

# ── 벡터 검색 백엔드 (선택) ─────────────────────────────────────────
# bruteforce(기본, 정확) | lsh(근사 최근접 ANN) | qdrant(외부 벡터 DB)
# VECTOR_BACKEND=lsh
# LSH_TABLES=4
# LSH_BITS=12

# VECTOR_BACKEND=qdrant 일 때 외부 Qdrant 인스턴스 연결 (미설정 시 bruteforce 폴백)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=silson_kb

# ── 원격 크롤러 (선택) ──────────────────────────────────────────────
# robots.txt를 준수하여 공개 출처를 수집한다. 이용약관·저작권·법적 검토를
# 통과한 URL만 쉼표로 구분하여 지정할 것. (npm run crawl:cases)
# CRAWL_URL=https://example.org/case/1,https://example.org/case/2
